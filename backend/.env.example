# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT.supabase.co:5432/postgres

# Server
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# Paystack (test keys)
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_PUBLIC_KEY=pk_test_replace_me
PAYSTACK_CALLBACK_URL=http://localhost:3001/api/payments/paystack/callback

# Moolre (mobile money account name verification)
MOOLRE_API_USER=replace_me
MOOLRE_API_KEY=replace_me
MOOLRE_ACCOUNT_NUMBER=replace_me

# Internal cron trigger for daily ROI accrual (POST /api/admin/run-daily-roi)
CRON_SECRET=change-me-in-production

# NOWPayments (USDT TRC20 crypto deposits)
NOWPAYMENTS_API_KEY=replace_me
NOWPAYMENTS_IPN_SECRET=replace_me
NOWPAYMENTS_IPN_CALLBACK_URL=https://your-domain.com/api/payments/crypto/ipn

# Logging
LOG_LEVEL=info
