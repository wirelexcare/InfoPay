VITE_API_URL=http://localhost:3001
VITE_APP_NAME=InfoPay
VITE_APP_URL=http://localhost:5173

# Supabase Realtime (chat typing indicators / live thread updates).
# The anon key is safe to expose client-side by design; broadcast payloads
# never carry message content, only "something changed" / typing signals.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=replace_me
